{
  "name": "@diplodoc/algolia-extension",
  "version": "0.5.2",
  "description": "Algolia search integration extension for Diplodoc",
  "repository": {
    "type": "git",
    "url": "git@github.com:diplodoc-platform/algolia-extension.git"
  },
  "engines": {
    "npm": ">=11.5.1",
    "node": ">=22"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "npm run build:clean && tsc && cp src/client/search.js dist/client/search.js",
    "build:types": "tsc --emitDeclarationOnly",
    "build:all": "npm run build && npm run build:types",
    "lint": "lint update && lint",
    "lint:fix": "lint update && lint fix",
    "pre-commit": "lint update && lint-staged",
    "prepare": "husky",
    "prepublishOnly": "npm run typecheck && npm run lint && npm run test && npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "format": "prettier --write \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "build:clean": "node scripts/clean.mjs"
  },
  "dependencies": {
    "@diplodoc/search-extension": "^1.0.0",
    "algoliasearch": "^5.24.0",
    "cheerio": "^1.0.0",
    "lodash": "^4.17.21",
    "ts-dedent": "^2.2.0"
  },
  "devDependencies": {
    "@diplodoc/cli": "^5.12.5",
    "@diplodoc/lint": "^1.13.2",
    "@diplodoc/tsconfig": "^1.0.2",
    "@types/lodash": "^4.14.202",
    "@types/node": "^22.19.7",
    "typescript": "^5.0.0",
    "vitest": "^3.2.4",
    "@vitest/coverage-v8": "^3.2.4"
  }
}
